{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenScreen Studio",
  "version": "0.1.0",
  "identifier": "com.openscreenstudio.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "permissions",
        "title": "OpenScreen Studio",
        "width": 720,
        "height": 760,
        "resizable": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true,
        "visible": false
      },
      {
        "label": "hud",
        "title": "OpenScreen Studio",
        "width": 900,
        "height": 75,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      },
      {
        "label": "editor",
        "title": "OpenScreen Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 25, "y": 27.5 },
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "$HOME/Movies/**",
            "$TEMP/**",
            "/System/Library/Desktop Pictures/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/ffmpeg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist"
    }
  }
}
